<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="app.controllers.SalesDashboardController"
            styleClass="root-pane"
            prefWidth="1000" prefHeight="640">

    <!-- Top Bar -->
    <top>
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>
            <Label text="🛒" style="-fx-font-size:18;"/>
            <VBox spacing="1">
                <Label text="Sales Transaction Panel" styleClass="panel-title"/>
                <Label fx:id="staffIdLabel" text="" styleClass="panel-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="transactionIdLabel" text="No active transaction"
                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#2C7BE5;"/>
            <Button id="logoutBtn" text="Logout" onAction="#handleLogout" styleClass="btn-logout"/>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" spacing="6" prefWidth="210">
            <padding><Insets top="20" right="14" bottom="20" left="14"/></padding>

            <Label text="TRANSACTION" styleClass="sidebar-section"/>
            <Button id="createTxnBtn"   text="+ Create Transaction"   onAction="#handleCreateTransaction"   styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button id="addItemBtn"     text="+ Add Item"             onAction="#handleAddItem"             styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button id="updateQtyBtn"   text="✎  Update Quantity"     onAction="#handleUpdateQuantity"      styleClass="sidebar-btn" maxWidth="Infinity"/>
            <Button id="removeItemBtn"  text="✖  Remove Item"         onAction="#handleRemoveItem"          styleClass="sidebar-btn" maxWidth="Infinity"/>

            <Separator/>

            <Button id="finalizeBtn"    text="✔  Finalize Transaction" onAction="#handleFinalizeTransaction" styleClass="sidebar-btn-green" maxWidth="Infinity"/>
            <Button id="abortBtn"       text="✖  Abort Transaction"    onAction="#handleAbortTransaction"    styleClass="sidebar-btn-red"   maxWidth="Infinity"/>

            <Separator/>

            <Button id="printReceiptBtn" text="🖨  Print Receipt"      onAction="#handlePrintReceipt"        styleClass="sidebar-btn-blue"  maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox styleClass="content-area" spacing="16">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Page header -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Active Transaction" styleClass="welcome-label"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- Transaction Items Table Card -->
            <VBox styleClass="table-card" spacing="10" VBox.vgrow="ALWAYS">
                <Label text="Items in Transaction" styleClass="card-title"/>

                <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                    <columns>
                        <TableColumn fx:id="colItemCode"  text="Item Code"   prefWidth="160"/>
                        <TableColumn fx:id="colQty"       text="Quantity"    prefWidth="110"/>
                        <TableColumn fx:id="colUnitPrice" text="Unit Price"  prefWidth="130"/>
                        <TableColumn fx:id="colLineTotal" text="Line Total"  prefWidth="140"/>
                    </columns>
                    <placeholder>
                        <Label text="Create a transaction and add items to see them here."
                               style="-fx-text-fill:#ADB5BD; -fx-font-size:13px;"/>
                    </placeholder>
                </TableView>

                <!-- Running Total -->
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Label text="Transaction Total:" style="-fx-font-size:14px; -fx-text-fill:#495057; -fx-font-weight:bold;"/>
                    <Label fx:id="totalLabel" text="₹ 0.00" styleClass="total-label"/>
                </HBox>
            </VBox>

        </VBox>
    </center>

</BorderPane>
